---
const navItems = [
  { label: "Home", href: "/" },
  { label: "Projects", href: "/projects/" },
  { label: "About", href: "/about/" },
  { label: "Contact", href: "/contact/" },
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<header class="header" role="banner">
  <nav class="header__nav container" aria-label="Primary navigation">
    <a href="/" class="header__logo" aria-label="Somesh Arora, Home">
      <span class="header__logo-text">SA</span>
    </a>

    <button
      class="header__menu-toggle"
      aria-expanded="false"
      aria-controls="nav-menu"
      aria-label="Toggle navigation menu"
    >
      <span class="header__menu-icon" aria-hidden="true"></span>
    </button>

    <ul id="nav-menu" class="header__links" role="list">
      {
        navItems.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class:list={[
                "header__link",
                { "header__link--active": isActive(href) },
              ]}
              aria-current={isActive(href) ? "page" : undefined}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--color-bg) 70%, transparent);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-bottom: 1px solid var(--color-border);
  }

  .header__nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .header__logo {
    display: flex;
    align-items: center;
    transition: all var(--duration-normal) var(--ease-out);
  }

  .header__logo:hover {
    transform: scale(1.05);
  }

  .header__logo-text {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background: var(--gradient-accent);
    color: #fff;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.05em;
    box-shadow: 0 0 20px rgba(59, 130, 246, 0.2);
  }

  .header__links {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .header__link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-tertiary);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    transition: all var(--duration-fast) var(--ease-out);
    position: relative;
  }

  .header__link:hover {
    color: var(--color-text);
    background: var(--color-card-bg-hover);
  }

  .header__link--active {
    color: var(--color-text);
    background: var(--color-card-bg-hover);
    border: 1px solid rgba(59, 130, 246, 0.3);
    box-shadow: 0 0 8px rgba(59, 130, 246, 0.1);
  }

  .header__menu-toggle {
    display: none;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    transition: background var(--duration-fast) var(--ease-out);
  }

  .header__menu-toggle:hover {
    background: var(--color-card-bg-hover);
  }

  .header__menu-icon {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--color-text);
    position: relative;
    transition: background var(--duration-fast) var(--ease-out);
  }

  .header__menu-icon::before,
  .header__menu-icon::after {
    content: "";
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--color-text);
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .header__menu-icon::before { top: -6px; }
  .header__menu-icon::after { top: 6px; }

  .header__menu-toggle[aria-expanded="true"] .header__menu-icon {
    background: transparent;
  }

  .header__menu-toggle[aria-expanded="true"] .header__menu-icon::before {
    transform: rotate(45deg) translate(4px, 4px);
  }

  .header__menu-toggle[aria-expanded="true"] .header__menu-icon::after {
    transform: rotate(-45deg) translate(4px, -4px);
  }

  @media (max-width: 640px) {
    .header__menu-toggle { display: flex; }

    .header__links {
      display: none;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      flex-direction: column;
      padding: var(--space-4) var(--container-padding) var(--space-6);
      background: color-mix(in srgb, var(--color-bg) 95%, transparent);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--color-border);
      gap: var(--space-1);
    }

    .header__links.is-open { display: flex; }

    .header__link {
      display: block;
      padding: var(--space-3) var(--space-4);
      font-size: var(--text-base);
      border-radius: var(--radius-md);
    }
  }
</style>

<script src="/scripts/mobile-nav.js" type="module"></script>
