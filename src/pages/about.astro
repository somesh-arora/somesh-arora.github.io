---
import BaseLayout from "@layouts/BaseLayout.astro";

const skills = [
  {
    category: "Languages & Frameworks",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="3"/><line x1="12" y1="18" x2="12" y2="18.01"/></svg>`,
    items: ["Swift", "SwiftUI", "UIKit", "Objective-C", "Combine", "Swift Concurrency", "Python"],
  },
  {
    category: "Apple Frameworks",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 014 4c0 1.95-1.4 3.58-3.25 3.93"/><path d="M8 6a4 4 0 018 0"/><circle cx="12" cy="17" r="4"/><path d="M12 13v-2.07"/><path d="M6.5 17H4"/><path d="M20 17h-2.5"/><path d="M12 21v-0.01"/></svg>`,
    items: ["Core Data", "Core Bluetooth", "Core Animation", "Core Location", "AVFoundation", "WidgetKit", "App Intents", "MapKit", "ARKit"],
  },
  {
    category: "Architecture & Patterns",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h18v18H3z"/><path d="M3 9h18"/><path d="M9 3v18"/></svg>`,
    items: ["MVVM", "Clean Architecture", "Modular Architecture", "Protocol-Oriented Programming", "Server-Driven UI", "SDK Design", "SPM", "CocoaPods"],
  },
  {
    category: "Testing & Tools",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>`,
    items: ["XCTest", "Swift Testing", "UI Testing", "Snapshot Testing", "Instruments", "Charles Proxy", "Crashlytics", "TestFlight", "Azure DevOps", "Git"],
  },
  {
    category: "Platforms & Services",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>`,
    items: ["Azure OpenAI", "Azure Cognitive Services", "BLE", "Protobuf", "RESTful APIs", "Firebase"],
  },
  {
    category: "Leadership",
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
    items: ["Engineering Management", "Team Leadership", "Cross-Functional Collaboration", "Product Thinking", "0-to-1 Development", "Accessibility / Inclusive Design"],
  },
];

const education = {
  school: "The University of Texas at Arlington",
  degree: "B.S. in Computer Science",
  years: "2014–2018",
};

const awards = [
  {
    title: "Microsoft Accessibility Gold Medal",
    org: "Microsoft",
    year: "2021",
    description: "Drove Flipgrid iOS from a 'C' accessibility rating to Gold Medal, achieved by only 5.6% of Engineering + Devices org teams.",
  },
  {
    title: "Dual Microsoft Hackathon Awards",
    org: "Microsoft",
    year: "2021",
    description: "Won People's Choice and Runner Up for 'Reimagining Flipgrid Comments'. Features were adopted into the official product roadmap.",
  },
  {
    title: "Most Inclusive Project, Fix Hack Learn",
    org: "Microsoft",
    year: "2020",
    description: "Built a real-time language translation prototype using Azure Cognitive Services, breaking language barriers for global education.",
  },
  {
    title: "Most Creative Project, Garmin Hackathon",
    org: "Garmin",
    year: "2019",
    description: "Won for an ARKit prototype exploring augmented reality applications for fitness and outdoor activities.",
  },
];

const impactNumbers = [
  { value: "6", label: "Features Shipped", context: "Launched to GA as Education squad DRI" },
  { value: "15x", label: "DAU Growth", context: "MSN Watch immersive video experience" },
  { value: "680%", label: "Rating Increase", context: "5-star App Store ratings" },
  { value: "8x", label: "Engagement Lift", context: "Onboarding redesign impact" },
  { value: "99.8%", label: "Crash-Free Rate", context: "While shipping at high velocity" },
  { value: "50%+", label: "Faster Launch", context: "App load time reduction" },
];

---

<BaseLayout
  title="About | Somesh Arora"
  description="Member of Technical Staff, iOS at Microsoft AI. From 0-to-1 prototypes to millions of users. Learn about Somesh's career, impact, and engineering philosophy."
>
  <section class="section" aria-labelledby="about-heading">
    <div class="container container--narrow">
      <h1 id="about-heading" class="section-heading">About</h1>

      <div class="about-profile fade-in">
        <img
          src="/images/profile/somesh-arora.jpg"
          alt="Somesh Arora"
          class="about-photo"
          width="160"
          height="160"
          loading="eager"
        />
        <div class="about-intro">
          <p class="about-lead">
            I'm a Member of Technical Staff, iOS at <strong>Microsoft AI</strong>, where I build and ship features
            on the Copilot iOS app to millions of users worldwide. My career has taken me from
            building BLE medical device apps at Abbott, to shipping fitness features at Garmin,
            to leading a team of 5 iOS engineers across Microsoft's ecosystem, and now to the
            frontier of AI-powered mobile experiences.
          </p>
        </div>
      </div>

      <div class="about-content fade-in">
        <h2>The Journey</h2>

        <p>
          I started building software that matters in 2017 at <strong>Abbott Laboratories</strong>,
          working on a Bluetooth Low Energy app for medical device prototyping. Seeing my code
          used by firmware teams across continents showed me the impact software can have beyond screens.
        </p>

        <p>
          After graduating from UT Arlington in 2018, I joined <strong>Garmin</strong>, contributing
          to the Garmin Connect app used by millions. I built strong foundations in UIKit, BLE
          systems, and Protobuf, and won Most Creative Project at Garmin's hackathon for an ARKit prototype.
        </p>

        <p>
          In 2020, I joined <strong>Microsoft</strong> as part of the Flipgrid team. Over the next
          few years, I focused on scale and inclusion, shipping Flipgrid's first mobile admin
          features, driving the app to Microsoft's Accessibility Gold Medal, and winning multiple
          internal hackathons.
        </p>

        <p>
          I was promoted to <strong>Senior Software Engineering Manager</strong> in 2022, leading
          a team of five iOS engineers across Bing, MSN, Skype, and Teams. During this time, I
          architected PlaybackKit, a cross-Microsoft video SDK, scaled MSN Watch by 15x, cut app
          load times by over 50%, and significantly improved App Store quality ratings.
        </p>

        <p>
          In 2025, I chose to return to the IC path at a higher level, joining
          <strong>Microsoft AI</strong> as a Member of Technical Staff. Today, I work on Copilot
          iOS, shipping flagship features like Deep Research Mode, leading education experiences,
          and architecting cross-platform systems adopted across iOS, Windows, and GroupMe. I
          regularly present early engineering prototypes to Microsoft AI leadership, helping shape
          Copilot at global scale.
        </p>

        <h2>What Drives Me</h2>

        <ol class="about-principles">
          <li>
            <strong>Build first, convince through demonstration.</strong> I don't wait for specs.
            I prototype, present, and build conviction. The best way to align stakeholders is to
            show them a working product.
          </li>
          <li>
            <strong>Accessibility is non-negotiable.</strong> I drove an app from a "C" rating
            to a Gold Medal. VoiceOver, Dynamic Type, and inclusive design are part of the spec,
            not an afterthought.
          </li>
          <li>
            <strong>Performance is UX.</strong> I've reduced app load times by 50%+ and maintained
            99.8%+ crash-free rates while shipping at high velocity. Every dropped frame is a
            broken promise.
          </li>
        </ol>

        <h2>Education</h2>
        <div class="about-education">
          <img src="/images/logos/uta.png" alt="UT Arlington logo" class="about-edu-logo" width="48" height="48" loading="lazy" />
          <div>
            <p><strong>{education.school}</strong></p>
            <p>{education.degree}</p>
            <p class="about-edu-years">{education.years}</p>
          </div>
        </div>

        <div class="about-resume">
          <a href="/Somesh_Arora_Resume.pdf" class="btn btn--secondary" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M8 2v8m0 0l-3-3m3 3l3-3M3 12v1a1 1 0 001 1h8a1 1 0 001-1v-1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Download Resume (PDF)
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Impact Numbers -->
  <section class="section section--compact" aria-labelledby="impact-heading">
    <div class="container container--narrow">
      <h2 id="impact-heading" class="section-heading">Impact by the Numbers</h2>
      <div class="impact-grid stagger-children">
        {impactNumbers.map(({ value, label, context }) => (
          <div class="impact-card fade-in" data-glow>
            <p class="impact-card__value">{value}</p>
            <p class="impact-card__label">{label}</p>
            <p class="impact-card__context">{context}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Awards -->
  <section class="section section--compact" aria-labelledby="awards-heading">
    <div class="container container--narrow">
      <h2 id="awards-heading" class="section-heading">Awards & Recognition</h2>
      <div class="awards-list stagger-children">
        {awards.map(({ title, org, year, description }) => (
          <div class="award-card fade-in" data-glow>
            <div class="award-card__header">
              <h3 class="award-card__title">{title}</h3>
              <span class="award-card__meta">{org} · {year}</span>
            </div>
            <p class="award-card__desc">{description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="section section--compact" aria-labelledby="skills-heading">
    <div class="container container--narrow">
      <h2 id="skills-heading" class="section-heading">Technical Skills</h2>
      <div class="skills-grid stagger-children">
        {
          skills.map(({ category, icon, items }) => (
            <div class="skills-card" data-glow>
              <div class="skills-card__header">
                <div class="skills-card__icon" set:html={icon} />
                <h3 class="skills-card__title">{category}</h3>
              </div>
              <div class="skills-card__tags">
                {items.map((skill) => (
                  <span class="tag">{skill}</span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--compact" style="text-align:center;" aria-labelledby="about-cta">
    <div class="container container--narrow">
      <h2 id="about-cta" class="section-heading">Want to work together?</h2>
      <p class="section-subheading" style="margin-inline:auto;">
        I'm open to staff-level iOS roles, AI collaborations, and high-impact engineering challenges.
      </p>
      <a href="/contact/" class="btn btn--primary">Get in Touch</a>
    </div>
  </section>
</BaseLayout>

<style>
  .section--compact {
    padding-block: var(--space-10);
  }

  .about-profile {
    display: flex;
    align-items: flex-start;
    gap: var(--space-8);
    margin-bottom: var(--space-8);
  }

  .about-photo {
    width: 160px;
    height: 160px;
    border-radius: var(--radius-lg);
    object-fit: cover;
    border: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .about-lead {
    font-size: var(--text-lg);
    color: var(--color-text);
    line-height: var(--leading-relaxed);
  }

  .about-content p {
    margin-bottom: var(--space-4);
  }

  .about-content h2 {
    font-size: var(--text-xl);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
  }

  .about-principles {
    list-style: decimal;
    padding-left: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .about-principles li {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .about-principles strong {
    color: var(--color-text);
  }

  .about-education {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-card-bg);
  }

  .about-edu-logo {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-sm);
    object-fit: contain;
    flex-shrink: 0;
  }

  .about-education p {
    margin-bottom: 0;
    color: var(--color-text-secondary);
  }

  .about-education strong {
    color: var(--color-text);
  }

  .about-edu-years {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    margin-top: var(--space-1);
  }

  .about-resume {
    margin-top: var(--space-6);
  }

  /* Impact Grid */
  .impact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  .impact-card {
    padding: var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-card-bg);
    text-align: center;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .impact-card__value {
    font-size: var(--text-3xl);
    font-weight: 800;
    background: var(--gradient-accent-text);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    line-height: 1;
    margin-bottom: var(--space-1);
  }

  .impact-card__label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .impact-card__context {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  /* Awards */
  .awards-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .award-card {
    padding: var(--space-5) var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-card-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    transition:
      border-color var(--duration-normal) var(--ease-out),
      background var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out),
      transform var(--duration-normal) var(--ease-out);
  }

  .award-card:hover {
    border-color: var(--color-border-hover);
    background: var(--color-card-bg-hover);
    box-shadow: var(--shadow-glow-sm);
    transform: translateY(-2px);
  }

  .award-card__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-bottom: var(--space-2);
  }

  .award-card__title {
    font-size: var(--text-base);
    font-weight: 600;
  }

  .award-card__meta {
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    white-space: nowrap;
  }

  .award-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin-bottom: 0;
  }

  /* Skills */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .skills-card {
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }

  .skills-card__header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .skills-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background: var(--gradient-subtle);
    border: 1px solid var(--color-border);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .skills-card__title {
    font-size: var(--text-base);
    font-weight: 600;
  }

  .skills-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    font-size: var(--text-xs);
    font-weight: 500;
    border-radius: var(--radius-full);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-full);
    transition:
      background var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn--primary {
    background: var(--color-text);
    color: var(--color-bg);
  }

  .btn--primary:hover {
    opacity: 0.85;
  }

  .btn--secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn--secondary:hover {
    background: var(--color-bg-secondary);
    border-color: var(--color-border-hover);
  }

  @media (max-width: 640px) {
    .about-profile {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .about-photo {
      width: 120px;
      height: 120px;
    }

    .impact-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .skills-grid {
      grid-template-columns: 1fr;
    }

    .award-card__header {
      flex-direction: column;
      gap: var(--space-1);
    }
  }
</style>
